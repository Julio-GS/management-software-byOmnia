# ====================================
# Railway Environment Variables
# ====================================

# BACKEND SERVICE
# ====================================
DATABASE_URL=${{Postgres.DATABASE_URL}}
NODE_ENV=production
PORT=8080

# JWT - Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_ME
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_ME
JWT_REFRESH_EXPIRES_IN=7d

# Admin User
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=REPLACE_ME
DEFAULT_ADMIN_FIRSTNAME=Admin
DEFAULT_ADMIN_LASTNAME=User

# CORS - Use Railway variable reference
FRONTEND_URL=${{web.RAILWAY_PUBLIC_DOMAIN}}

# FRONTEND SERVICE (web)
# ====================================
NEXT_PUBLIC_API_URL=${{backend.RAILWAY_PUBLIC_DOMAIN}}/api/v1
NODE_ENV=production
