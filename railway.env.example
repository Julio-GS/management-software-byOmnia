# ====================================
# Railway Environment Variables Template
# ====================================
# Copy these variables to your Railway project settings
# Replace placeholder values with your actual configuration

# ====================================
# DATABASE (PostgreSQL)
# ====================================
# Railway will automatically provide this when you add a PostgreSQL service
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/management_db

# ====================================
# BACKEND (NestJS) - Port 3001
# ====================================

# Application
NODE_ENV=production
PORT=3001
API_PREFIX=api

# JWT Authentication
# Generate a secure random string for JWT_SECRET (use: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Admin User (for initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-secure-password

# CORS Configuration
# Set this to your frontend URL (Railway will provide this)
CORS_ORIGIN=https://your-app.railway.app

# ====================================
# FRONTEND (Next.js) - Port 3000
# ====================================

# API URL - Backend service URL
# In Railway, use internal networking: http://backend-service:3001
# For external access, use the Railway-provided URL
NEXT_PUBLIC_API_URL=https://your-backend.railway.app/api

# Alternative for Railway internal networking:
# NEXT_PUBLIC_API_URL=http://localhost:3001/api

# NextAuth (if using authentication)
NEXTAUTH_URL=https://your-app.railway.app
NEXTAUTH_SECRET=your-nextauth-secret-change-this

# ====================================
# OPTIONAL SERVICES
# ====================================

# Redis (if needed for caching)
# REDIS_URL=redis://redis.railway.internal:6379

# Sentry (for error tracking)
# SENTRY_DSN=your-sentry-dsn

# AWS S3 (for file uploads)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ====================================
# NOTES
# ====================================
# 1. Railway automatically sets PORT and DATABASE_URL
# 2. Use Railway's internal networking for service-to-service communication
# 3. Generate secure random strings for all secrets
# 4. Never commit actual secrets to version control
# 5. Update CORS_ORIGIN to match your actual domain
