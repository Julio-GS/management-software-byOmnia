# ==========================================
# OMNIA MANAGEMENT SYSTEM - .gitignore
# ==========================================

# ==========================================
# DOCUMENTATION & ARCHITECTURE (EXCLUDED)
# ==========================================

# Root-level documentation (exclude all except workspace READMEs)
#/*.md
!README.md

# Documentation directory
docs/
*.png
*.jpg
*.jpeg
*.svg
*.gif
*.pdf

# Architecture and planning files
#Arquitectura-roadmap.md
definiciones de arq y casos edge.txt
grafico arquitectura.png
HANDOFF_TO_ORCHESTRATOR.md

# Bug reports and checklists
BUGFIX*.md
GIT_COMMIT_CHECKLIST.md

# Session summaries and test plans
SESSION_SUMMARY*.md
*-test-plan.md
*-implementation-report.md
*-implementation-summary.md
QUICK_START*.md

# ==========================================
# NODE.JS & PACKAGE MANAGERS
# ==========================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Lock files (keep pnpm-lock.yaml for reproducible builds)
# Uncomment if you want to exclude lock files:
# pnpm-lock.yaml
# package-lock.json
# yarn.lock

# ==========================================
# BUILD OUTPUTS
# ==========================================

# Next.js
.next/
out/
build/
dist/

# Turbo
.turbo/
*.log

# Electron
apps/desktop/dist/
apps/desktop/out/
apps/desktop/build/

# TypeScript
*.tsbuildinfo
*.tsbuildinfo.*

# ==========================================
# ENVIRONMENT & SECRETS
# ==========================================

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Keep example files
!.env.example
!.env.sample

# ==========================================
# OPERATING SYSTEM FILES
# ==========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ==========================================
# IDE & EDITOR FILES
# ==========================================

# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.ipr
*.iws
.idea_modules/
atlassian-ide-plugin.xml
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ==========================================
# LOGS & TEMPORARY FILES
# ==========================================

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Coverage
coverage/
*.lcov
.nyc_output/
lib-cov/

# ==========================================
# TESTING
# ==========================================

# Jest
/coverage
.jest-cache

# Playwright
test-results/
playwright-report/
playwright/.cache/

# ==========================================
# DATABASES (Phase 2+)
# ==========================================

# SQLite
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# PostgreSQL local dumps
*.sql
*.dump

# Prisma
# Keep schema but exclude generated client and migrations in dev
# Uncomment if needed:
# prisma/migrations/

# ==========================================
# DEPLOYMENT & CLOUD
# ==========================================

# Vercel
.vercel
.vercel.json

# Docker
.dockerignore
docker-compose.override.yml

# Serverless
.serverless/

# ==========================================
# MISCELLANEOUS
# ==========================================

# v0 runtime files (AI-generated code)
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts

# Backup files
*.bak
*.backup
*~.nib

# Compressed files (unless intentionally part of project)
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Cache directories
.cache/
.npm/
.eslintcache
.stylelintcache

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache
.cache
.parcel-cache

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ==========================================
# WORKSPACE-SPECIFIC IGNORES
# ==========================================

# Keep workspace README files
!apps/*/README.md
!packages/*/README.md

# Migration logs (scripts directory)
scripts/*-log-*.json
scripts/migration-log-*.json

# Verification scripts (keep .sh but ignore .ps1 if sensitive)
# verify-bugfix.ps1
# verify-bugfix.sh
