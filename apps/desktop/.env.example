# ============================================
# OMNIA DESKTOP - ENVIRONMENT CONFIGURATION
# ============================================
#
# This file contains environment variables for the desktop application.
# Copy this file to .env and update with your values.
#
# IMPORTANT: Never commit .env files to version control!

# ------------------------------
# Backend API Configuration
# ------------------------------
BACKEND_URL=http://localhost:8080

# ------------------------------
# Frontend Dev Server (Next.js)
# ------------------------------
# Only used in development mode
ELECTRON_DEV_URL=http://localhost:3000

# ------------------------------
# Desktop Auto-Login Credentials
# ------------------------------
# These credentials are used for automatic authentication.
# The cashier will NOT see a login screen - the app logs in automatically.

DESKTOP_USER_EMAIL=caja1@supermercado.com
DESKTOP_USER_PASSWORD=CajaSegura2024!

# ------------------------------
# Device Identification
# ------------------------------
# Unique identifier for this desktop installation.
# If not provided, a random ID will be generated and used.
# For production: Set a meaningful ID for each terminal.

DESKTOP_DEVICE_ID=caja-001

# ------------------------------
# Optional: Store Information
# ------------------------------
# If you have multiple stores, specify which store this terminal belongs to.

DESKTOP_STORE_ID=tienda-central

# ------------------------------
# Development Settings
# ------------------------------
# Set to 'true' to enable debug logging
DEBUG=false

# Set log level: 'error' | 'warn' | 'info' | 'debug'
LOG_LEVEL=info
