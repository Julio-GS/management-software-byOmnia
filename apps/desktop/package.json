{
  "name": "@omnia/desktop",
  "version": "1.0.0",
  "description": "Electron desktop application for Omnia Management System",
  "main": "dist/electron/main.js",
  "private": true,
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "node esbuild.config.js && cross-env NODE_ENV=development electron .",
    "dev:compile": "tsc --watch",
    "build:electron": "node esbuild.config.js",
    "build": "node esbuild.config.js && electron-builder",
    "build:dir": "node esbuild.config.js && electron-builder --dir",
    "clean": "rm -rf dist release",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.omnia.management",
    "productName": "Omnia Management",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "!**/*.ts",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "../web/out",
        "to": "web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@omnia/local-db": "workspace:*",
    "@omnia/shared-types": "workspace:*",
    "axios": "^1.13.6",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.3.1",
    "electron-log": "^5.1.1",
    "electron-updater": "^6.1.8",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.11.19",
    "cross-env": "^7.0.3",
    "electron": "28.0.0",
    "electron-builder": "^24.13.3",
    "electronmon": "^2.0.4",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.3"
  }
}
