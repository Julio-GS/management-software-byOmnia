# Database Configuration
DATABASE_URL="postgresql://username:password@host:5432/database_name?schema=public"

# Server Configuration
PORT=8080
NODE_ENV=development

# JWT Configuration
# MVP Authentication: Simple stateless JWT with 7-day expiry
# - Access tokens valid for 7 days (no refresh rotation)
# - No Redis blacklist (stateless approach)
# - Security: Use strong JWT_SECRET (32+ chars recommended)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Feature Flags
# Sales Refactor: Enable repository pattern + event emission (default: false)
# Set to true to use new ISalesRepository implementation
# Rollback: set to false to use legacy Prisma-based implementation
ENABLE_SALES_REFACTOR=false

# Products Cache: Enable in-memory caching for product list (default: false)
# Set to true to cache findAll() results with 5-min TTL
# Rollback: set to false to disable caching (direct DB queries)
ENABLE_PRODUCTS_CACHE=false

# Dashboard Cache: Enable in-memory caching for dashboard metrics (default: false)
# Set to true to cache getDashboardMetrics() results with 2-min TTL
# Rollback: set to false to disable caching (direct DB queries)
ENABLE_DASHBOARD_CACHE=false

# Default Admin User (for seeding)
DEFAULT_ADMIN_EMAIL=admin@omnia.com
DEFAULT_ADMIN_PASSWORD=Admin123!
DEFAULT_ADMIN_FIRSTNAME=System
DEFAULT_ADMIN_LASTNAME=Administrator

# CORS Configuration
# Development: Local frontend dev server
FRONTEND_URL=http://localhost:3000
# Production: Replace with your actual domain
# FRONTEND_URL=https://your-domain.com
# SECURITY WARNING: Never use '*' (wildcard) - it's a security risk with credentials
