// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Product entity - Core inventory item
model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  sku         String   @unique
  barcode     String?  @unique
  price       Decimal  @db.Decimal(10, 2)
  cost        Decimal  @db.Decimal(10, 2)
  markup      Decimal? @db.Decimal(10, 2) // Product-specific markup percentage (overrides category/global)
  stock       Int      @default(0)
  minStock    Int      @default(0)
  maxStock    Int?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  isActive    Boolean  @default(true)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // Soft delete support

  // Relations
  saleItems         SaleItem[]
  inventoryMovements InventoryMovement[]

  @@index([categoryId])
  @@index([sku])
  @@index([barcode])
  @@map("products")
}

// Category entity - Product categorization
model Category {
  id           String    @id @default(uuid())
  name         String    @unique
  description  String?
  defaultMarkup Decimal? @db.Decimal(10, 2) // Category-level default markup percentage
  parentId     String?
  parent       Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryHierarchy")
  color        String?   // Hex color for UI
  icon         String?   // Icon identifier
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // Soft delete support

  // Relations
  products Product[]

  @@index([parentId])
  @@map("categories")
}

// Sale entity - Transaction record
model Sale {
  id              String   @id @default(uuid())
  saleNumber      String   @unique
  totalAmount     Decimal  @db.Decimal(10, 2)
  subtotal        Decimal  @db.Decimal(10, 2)
  taxAmount       Decimal  @db.Decimal(10, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(10, 2)
  paymentMethod   String   // 'cash', 'card', 'transfer', 'mixed'
  status          String   @default("completed") // 'pending', 'completed', 'cancelled', 'refunded'
  customerId      String?
  customerName    String?
  customerEmail   String?
  notes           String?
  cashierId       String?  // User ID who processed the sale
  deviceId        String?  // Device identifier for sync
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  items SaleItem[]

  @@index([saleNumber])
  @@index([status])
  @@index([createdAt])
  @@map("sales")
}

// SaleItem entity - Individual items in a sale
model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)
  taxAmount   Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

// Movement type enum
enum MovementType {
  ENTRY       // Stock entry (purchase, returns, etc.)
  EXIT        // Stock exit (sale, loss, etc.)
  ADJUSTMENT  // Manual stock adjustment/correction
}

// InventoryMovement entity - Stock tracking
model InventoryMovement {
  id          String       @id @default(uuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  type        MovementType
  quantity    Int
  previousStock Int
  newStock    Int
  reason      String?      // Human-readable reason for the movement
  reference   String?      // External reference (purchase order, sale ID, etc.)
  notes       String?
  userId      String?      // Who made the movement
  user        User?        @relation(fields: [userId], references: [id], onDelete: Restrict)
  deviceId    String?      // Device identifier for sync
  createdAt   DateTime     @default(now())

  @@index([productId])
  @@index([type])
  @@index([userId])
  @@index([createdAt])
  @@map("inventory_movements")
}

// SyncLog entity - Multi-device synchronization tracking
model SyncLog {
  id          String   @id @default(uuid())
  deviceId    String
  entityType  String   // 'product', 'sale', 'inventory', 'category'
  entityId    String
  operation   String   // 'create', 'update', 'delete'
  data        Json?    // Snapshot of the entity data
  syncStatus  String   @default("pending") // 'pending', 'synced', 'conflict', 'failed'
  errorMessage String?
  attempts    Int      @default(0)
  lastAttempt DateTime?
  syncedAt    DateTime?
  createdAt   DateTime @default(now())

  @@index([deviceId])
  @@index([entityType])
  @@index([syncStatus])
  @@index([createdAt])
  @@map("sync_logs")
}

// User entity - System users with role-based access
model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String   // Hashed with bcrypt
  firstName   String
  lastName    String
  role        String   @default("cashier") // 'admin', 'manager', 'cashier'
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  inventoryMovements InventoryMovement[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// Settings entity - Application-wide configuration
model Settings {
  id        String   @id @default(uuid())
  key       String   @unique // Setting identifier (e.g., 'globalMarkup', 'taxRate')
  value     Json     // JSON value for flexibility (numbers, strings, objects, arrays)
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("settings")
}
