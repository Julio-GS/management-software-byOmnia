generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NestJS Auth User Model (separate from legacy usuarios table)
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String?  @unique
  password  String
  firstName String
  lastName  String
  role      String   @default("cashier")
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([role])
  @@map("users")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model cajas {
  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  numero       Int            @unique
  nombre       String         @db.VarChar(100)
  descripcion  String?
  activo       Boolean?       @default(true)
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  cierres_caja cierres_caja[]
  ventas       ventas[]

  @@index([numero], map: "idx_cajas_numero")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model cierres_caja {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  caja_id             String    @db.Uuid
  fecha               DateTime  @db.Date
  total_efectivo      Decimal?  @default(0) @db.Decimal(12, 2)
  total_debito        Decimal?  @default(0) @db.Decimal(12, 2)
  total_credito       Decimal?  @default(0) @db.Decimal(12, 2)
  total_transferencia Decimal?  @default(0) @db.Decimal(12, 2)
  total_qr            Decimal?  @default(0) @db.Decimal(12, 2)
  total_ventas        Decimal   @default(0) @db.Decimal(12, 2)
  efectivo_sistema    Decimal?  @db.Decimal(12, 2)
  efectivo_fisico     Decimal?  @db.Decimal(12, 2)
  diferencia_efectivo Decimal?  @db.Decimal(12, 2)
  motivo_diferencia   String?
  usuario_id          String?   @db.Uuid
  observaciones       String?
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  cajas               cajas     @relation(fields: [caja_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios            usuarios? @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([caja_id, fecha], map: "uq_cierre_caja_fecha")
  @@index([caja_id], map: "idx_cierres_caja")
  @@index([fecha(sort: Desc)], map: "idx_cierres_fecha")
}

